<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.SnowTimSwiss.TimENC</id>

  <name>TimENC</name>
  <summary>Secure file encryption tool</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-only</project_license>

  <developer id="io.github.SnowTimSwiss">
    <name>SnowTimSwiss</name>
  </developer>

  <description>
    <p>
      TimENC is a secure file encryption tool. It protects your files using
      ChaCha20-Poly1305 authenticated encryption with Argon2id key derivation.
    </p>
    <p>Features:</p>
    <ul>
      <li>ChaCha20-Poly1305 authenticated encryption</li>
      <li>Argon2id password-based key derivation</li>
      <li>Simple, cross-platform graphical interface</li>
    </ul>
  </description>

  <launchable type="desktop-id">io.github.SnowTimSwiss.TimENC.desktop</launchable>

