{
  "$schema": "https://schema.tauri.app/tauri.conf.json",
  "productName": "TimENC",
  "version": "2.2.1",
  "identifier": "com.timenc",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "dist",
    "devUrl": "http://localhost:1420",
    "removeUnusedCommands": true
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "fullscreen": false,
        "height": 620,
        "resizable": true,
        "title": "TimENC - Secure Encryption",
        "width": 1000,
        "minWidth": 800,
        "minHeight": 540
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Utility",
    "copyright": "GPL-3.0",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "fileAssociations": [
      {
        "ext": ["timenc"],
        "name": "TimENC Encrypted File",
        "description": "TimENC encrypted container",
        "mimeType": "application/x-timenc",
        "role": "Editor"
      }
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "shortDescription": "Secure Encryption Tool",
    "longDescription": "TimENC - Secure file encryption with ChaCha20-Poly1305 and Argon2id"
  }
}
